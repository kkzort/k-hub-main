rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function premiumFields() {
      return [
        'isPremium',
        'premiumStatus',
        'premiumPlan',
        'premiumSource',
        'premiumPurchaseId',
        'premiumProductId',
        'premiumTransactionDate',
        'premiumLastVerification',
        'premiumActivatedAt',
        'premiumUpdatedAt',
      ];
    }

    function restrictedUserFields() {
      return [
        'isPremium',
        'premiumStatus',
        'premiumPlan',
        'premiumSource',
        'premiumPurchaseId',
        'premiumProductId',
        'premiumTransactionDate',
        'premiumLastVerification',
        'premiumActivatedAt',
        'premiumUpdatedAt',
        'role',
        'isApproved',
        'approvedAt',
        'isBanned',
        'banReason',
        'bannedAt',
        'isVerified',
        'verifiedAt',
      ];
    }

    function safeUserBootstrapValues() {
      return (!('role' in request.resource.data) || request.resource.data.role == 'student') &&
        (!('isApproved' in request.resource.data) || request.resource.data.isApproved == false) &&
        (!('isBanned' in request.resource.data) || request.resource.data.isBanned == false) &&
        (!('isVerified' in request.resource.data) || request.resource.data.isVerified == false) &&
        !request.resource.data.keys().hasAny(premiumFields());
    }

    function ownerTouchesRestrictedFields() {
      return request.resource.data.diff(resource.data).changedKeys().hasAny(restrictedUserFields());
    }

    // Kullanıcılar - giriş yapmış herkes okuyabilir, sadece kendi profilini yazabilir
    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isOwner(userId) && safeUserBootstrapValues();
      allow update: if isAdmin() || (isOwner(userId) && !ownerTouchesRestrictedFields());
      allow delete: if isAdmin() || isOwner(userId);
    }

    // Premium satin alma fisleri sadece backend (Admin SDK) tarafindan yazilir.
    match /premium_receipts/{receiptId} {
      allow read, write: if false;
    }

    // Mesajlar (Kampüs Sohbet) - giriş yapmış herkes okuyup yazabilir
    match /messages/{messageId} {
      allow read, write: if signedIn();
    }

    // DM Konuşmalar - sadece katılımcılar erişebilir
    match /conversations/{conversationId} {
      allow create: if signedIn() &&
        request.resource.data.participantIds is list &&
        request.auth.uid in request.resource.data.participantIds;
      allow read, update, delete: if signedIn() &&
        request.auth.uid in resource.data.participantIds;

      // Alt koleksiyon: mesajlar
      match /messages/{msgId} {
        allow read, write: if signedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
    }

    // Gönderiler (Sosyal) - giriş yapmış herkes okuyabilir
    match /posts/{postId} {
      allow read, write: if signedIn();

      match /comments/{commentId} {
        allow read, write: if signedIn();
      }
    }

    // Hikayeler
    match /stories/{storyId} {
      allow read, write: if signedIn();
    }

    // Arkadaşlıklar
    match /friendships/{friendshipId} {
      allow read, write: if signedIn();
    }

    // Notlar
    match /notes/{noteId} {
      allow read, write: if signedIn();

      match /comments/{commentId} {
        allow read, write: if signedIn();
      }
    }

    // Bildirimler
    match /notifications/{notifId} {
      allow read, write: if signedIn();
    }

    // Sohbet ayarları
    match /chat_settings/{settingId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // Kampus harita yerleri
    match /places/{placeId} {
      allow read, write: if signedIn();

      match /ratings/{ratingId} {
        allow read, write: if signedIn();
      }

      match /comments/{commentId} {
        allow read, write: if signedIn();
      }
    }

    // Etkinlikler
    match /events/{eventId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // Etkinlik on kayitlari
    match /event_preregistrations/{registrationId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
    }

    match /polls/{pollId} {
      allow read, write: if signedIn();
    }

    match /announcements/{announcementId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /reports/{reportId} {
      allow create: if signedIn();
      allow read, update, delete: if isAdmin();
    }

    match /tools/{toolId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /tools_meta/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /profile_visits/{visitId} {
      allow create: if signedIn() && request.resource.data.visitorId == request.auth.uid;
      allow read: if isAdmin() ||
        (signedIn() &&
          (resource.data.profileOwnerId == request.auth.uid || resource.data.visitorId == request.auth.uid));
      allow update, delete: if isAdmin();
    }
  }
}
