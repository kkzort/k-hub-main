# Uncomment this line to define a global platform for your project
platform :ios, '16.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

def patch_pods_copy_scripts(installer)
  support_dir = File.join(installer.sandbox.root.to_s, 'Target Support Files', 'Pods-Runner')
  frameworks_script = File.join(support_dir, 'Pods-Runner-frameworks.sh')
  resources_script = File.join(support_dir, 'Pods-Runner-resources.sh')

  if File.exist?(frameworks_script)
    content = File.read(frameworks_script)
    unless content.include?('export COPYFILE_DISABLE=1')
      content.sub!(
        "trap 'on_error $LINENO' ERR\n",
        "trap 'on_error $LINENO' ERR\n\n# Prevent metadata (xattr/resource fork) from being copied into app bundle.\nexport COPYFILE_DISABLE=1\n"
      )
    end
    unless content.include?('xattr -rc "${destination}/$(basename "$1")" || true')
      content.sub!(
        "  # Resign the code if required by the build settings to avoid unstable apps\n",
        "  # Resign the code if required by the build settings to avoid unstable apps\n  xattr -rc \"${destination}/$(basename \"$1\")\" || true\n"
      )
    end
    File.write(frameworks_script, content)
  end

  if File.exist?(resources_script)
    content = File.read(resources_script)
    unless content.include?('export COPYFILE_DISABLE=1')
      content.sub!(
        "trap 'on_error $LINENO' ERR\n",
        "trap 'on_error $LINENO' ERR\n\n# Prevent metadata (xattr/resource fork) from being copied into app bundle.\nexport COPYFILE_DISABLE=1\n"
      )
    end
    unless content.include?('xattr -rc "${TARGET_BUILD_DIR}/${FRAMEWORKS_FOLDER_PATH}/$(basename "$RESOURCE_PATH")" || true')
      content.sub!(
        "      rsync --delete -av \"${RSYNC_PROTECT_TMP_FILES[@]}\" \"$RESOURCE_PATH\" \"${TARGET_BUILD_DIR}/${FRAMEWORKS_FOLDER_PATH}\"\n",
        "      rsync --delete -av \"${RSYNC_PROTECT_TMP_FILES[@]}\" \"$RESOURCE_PATH\" \"${TARGET_BUILD_DIR}/${FRAMEWORKS_FOLDER_PATH}\"\n      xattr -rc \"${TARGET_BUILD_DIR}/${FRAMEWORKS_FOLDER_PATH}/$(basename \"$RESOURCE_PATH\")\" || true\n"
      )
    end
    unless content.include?('xattr -rc "${TARGET_BUILD_DIR}/${UNLOCALIZED_RESOURCES_FOLDER_PATH}" || true')
      content.sub!(
        "rsync -avr --copy-links --no-relative --exclude '*/.svn/*' --files-from=\"$RESOURCES_TO_COPY\" / \"${TARGET_BUILD_DIR}/${UNLOCALIZED_RESOURCES_FOLDER_PATH}\"\n",
        "rsync -avr --copy-links --no-relative --exclude '*/.svn/*' --files-from=\"$RESOURCES_TO_COPY\" / \"${TARGET_BUILD_DIR}/${UNLOCALIZED_RESOURCES_FOLDER_PATH}\"\nxattr -rc \"${TARGET_BUILD_DIR}/${UNLOCALIZED_RESOURCES_FOLDER_PATH}\" || true\n"
      )
    end
    unless content.include?('xattr -rc "${INSTALL_DIR}/${UNLOCALIZED_RESOURCES_FOLDER_PATH}" || true')
      content.sub!(
        "  rsync -avr --copy-links --no-relative --exclude '*/.svn/*' --files-from=\"$RESOURCES_TO_COPY\" / \"${INSTALL_DIR}/${UNLOCALIZED_RESOURCES_FOLDER_PATH}\"\n",
        "  rsync -avr --copy-links --no-relative --exclude '*/.svn/*' --files-from=\"$RESOURCES_TO_COPY\" / \"${INSTALL_DIR}/${UNLOCALIZED_RESOURCES_FOLDER_PATH}\"\n  xattr -rc \"${INSTALL_DIR}/${UNLOCALIZED_RESOURCES_FOLDER_PATH}\" || true\n"
      )
    end
    File.write(resources_script, content)
  end
end

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
    end
  end
  patch_pods_copy_scripts(installer)
  # Strip extended attributes to prevent CodeSign resource fork errors
  system("xattr -rc #{installer.sandbox.root} 2>/dev/null")
end
